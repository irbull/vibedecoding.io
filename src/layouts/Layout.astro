---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="VibeDecoding - The pragmatic engineer's guide to AI Base Software Development. Learn LLM fundamentals, fine tuning, inference, agents, and building AI-native developer tools." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	html {
		font-family: 'IBM Plex Mono', monospace;
		scroll-behavior: smooth;
		background: #fafafa;
		color: #1a1a1a;
	}
	body {
		margin: 0;
		padding: 0;
		background: #fafafa;
	}
</style>
